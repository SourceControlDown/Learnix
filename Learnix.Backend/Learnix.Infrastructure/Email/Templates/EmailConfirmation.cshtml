@model Learnix.Infrastructure.Email.Models.EmailConfirmationModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = Model.Strings["EmailConfirmation_Subject"].Value;
}

<h1 class="email-heading">@string.Format(Model.Strings["EmailConfirmation_Greeting"], Model.FirstName)</h1>
<p class="email-text-lg">
    @Model.Strings["EmailConfirmation_Body"]
</p>
<table cellpadding="0" cellspacing="0" class="email-button-container">
    <tr>
        <td class="email-button-bg">
            <a href="@Model.ConfirmationLink" class="email-button">
                @Model.Strings["EmailConfirmation_Button"]
            </a>
        </td>
    </tr>
</table>
