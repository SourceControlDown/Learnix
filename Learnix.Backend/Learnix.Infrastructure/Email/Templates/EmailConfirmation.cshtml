@model Learnix.Infrastructure.Email.Models.EmailConfirmationModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = "Підтвердіть електронну пошту";
}

<h1 class="email-heading">Привіт, @Model.FirstName!</h1>
<p class="email-text-lg">
    Дякуємо за реєстрацію на <strong>Learnix</strong>. Натисніть кнопку нижче, щоб підтвердити вашу електронну пошту та активувати акаунт.
</p>
<table cellpadding="0" cellspacing="0" class="email-button-container">
    <tr>
        <td class="email-button-bg">
            <a href="@Model.ConfirmationLink" class="email-button">
                Підтвердити пошту
            </a>
        </td>
    </tr>
</table>
<p class="email-text-sm">Якщо кнопка не працює, скопіюйте посилання:</p>
<p style="margin:0;word-break:break-all;">
    <a href="@Model.ConfirmationLink" class="email-link-sm">@Model.ConfirmationLink</a>
</p>
