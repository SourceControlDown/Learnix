@model Learnix.Infrastructure.Email.Models.PasswordResetModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = "Скидання пароля";
}

<h1 class="email-heading">Привіт, @Model.FirstName!</h1>
<p class="email-text-lg">
    Ми отримали запит на скидання пароля для вашого акаунта <strong>Learnix</strong>.
    Натисніть кнопку нижче, щоб встановити новий пароль. Посилання дійсне 1 годину.
</p>
<table cellpadding="0" cellspacing="0" class="email-button-container">
    <tr>
        <td class="email-button-bg">
            <a href="@Model.ResetLink" class="email-button">
                Скинути пароль
            </a>
        </td>
    </tr>
</table>
<p class="email-text-sm">Якщо кнопка не працює, скопіюйте посилання:</p>
<p style="margin:0;word-break:break-all;">
    <a href="@Model.ResetLink" class="email-link-sm">@Model.ResetLink</a>
</p>
<br/>
<p class="email-text-sm">Якщо ви не робили цей запит — проігноруйте лист. Пароль залишиться незмінним.</p>
