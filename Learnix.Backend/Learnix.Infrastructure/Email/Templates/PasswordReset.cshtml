@model Learnix.Infrastructure.Email.Models.PasswordResetModel
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Скидання пароля</title>
</head>
<body style="margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;background-color:#f3f4f6;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f3f4f6;padding:48px 16px;">
    <tr>
      <td align="center">
        <table width="560" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,0.08);">
          <tr>
            <td style="background-color:#4f46e5;padding:28px 40px;text-align:center;">
              <span style="color:#ffffff;font-size:22px;font-weight:700;letter-spacing:0.5px;">Learnix</span>
            </td>
          </tr>
          <tr>
            <td style="padding:40px;">
              <h1 style="margin:0 0 12px;color:#111827;font-size:20px;font-weight:700;">Привіт, @Model.FirstName!</h1>
              <p style="margin:0 0 28px;color:#4b5563;font-size:15px;line-height:1.7;">
                Ми отримали запит на скидання пароля для вашого акаунта <strong>Learnix</strong>.
                Натисніть кнопку нижче, щоб встановити новий пароль. Посилання дійсне 1 годину.
              </p>
              <table cellpadding="0" cellspacing="0" style="margin:0 0 32px;">
                <tr>
                  <td style="background-color:#4f46e5;border-radius:6px;">
                    <a href="@Model.ResetLink"
                       style="display:inline-block;padding:14px 32px;color:#ffffff;font-size:15px;font-weight:600;text-decoration:none;">
                      Скинути пароль
                    </a>
                  </td>
                </tr>
              </table>
              <p style="margin:0 0 6px;color:#6b7280;font-size:13px;">Якщо кнопка не працює, скопіюйте посилання:</p>
              <p style="margin:0;word-break:break-all;">
                <a href="@Model.ResetLink" style="color:#4f46e5;font-size:13px;">@Model.ResetLink</a>
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 40px;border-top:1px solid #e5e7eb;text-align:center;">
              <p style="margin:0;color:#9ca3af;font-size:12px;">Якщо ви не робили цей запит — проігноруйте лист. Пароль залишиться незмінним.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
