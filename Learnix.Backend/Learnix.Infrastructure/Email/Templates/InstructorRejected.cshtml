@model Learnix.Infrastructure.Email.Models.InstructorRejectedModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = "Заявку відхилено";
}

<h1 class="email-heading">Привіт, @Model.FirstName!</h1>
<p class="email-text">
    На жаль, вашу заявку на отримання ролі <strong>Інструктора</strong> на платформі Learnix було <strong>відхилено</strong>.
</p>
@if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
{
    <div class="callout-danger">
        <p class="callout-danger-text"><strong>Причина:</strong> @Model.RejectionReason</p>
    </div>
}
<p class="email-text">
    Ви можете подати нову заявку після усунення зазначених недоліків.
</p>
