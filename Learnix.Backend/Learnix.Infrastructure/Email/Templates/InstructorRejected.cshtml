@model Learnix.Infrastructure.Email.Models.InstructorRejectedModel
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Заявку відхилено</title>
</head>
<body style="margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;background-color:#f3f4f6;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f3f4f6;padding:48px 16px;">
    <tr>
      <td align="center">
        <table width="560" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,0.08);">
          <tr>
            <td style="background-color:#4f46e5;padding:28px 40px;text-align:center;">
              <span style="color:#ffffff;font-size:22px;font-weight:700;letter-spacing:0.5px;">Learnix</span>
            </td>
          </tr>
          <tr>
            <td style="padding:40px;">
              <h1 style="margin:0 0 12px;color:#111827;font-size:20px;font-weight:700;">Привіт, @Model.FirstName!</h1>
              <p style="margin:0 0 20px;color:#4b5563;font-size:15px;line-height:1.7;">
                На жаль, вашу заявку на отримання ролі <strong>Інструктора</strong> на платформі Learnix було <strong>відхилено</strong>.
              </p>
              @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
              {
                <div style="background-color:#fef2f2;border-left:4px solid #ef4444;padding:16px 20px;border-radius:0 6px 6px 0;margin-bottom:20px;">
                  <p style="margin:0;color:#7f1d1d;font-size:14px;line-height:1.6;"><strong>Причина:</strong> @Model.RejectionReason</p>
                </div>
              }
              <p style="margin:0;color:#4b5563;font-size:15px;line-height:1.7;">
                Ви можете подати нову заявку після усунення зазначених недоліків.
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 40px;border-top:1px solid #e5e7eb;text-align:center;">
              <p style="margin:0;color:#9ca3af;font-size:12px;">© Learnix — Платформа онлайн-навчання</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
