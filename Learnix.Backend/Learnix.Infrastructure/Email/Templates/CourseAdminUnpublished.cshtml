@model Learnix.Infrastructure.Email.Models.CourseAdminActionModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = Model.Strings["CourseAdminUnpublished_Subject"].Value;
}

<h1 class="email-heading">@string.Format(Model.Strings["CourseAdminUnpublished_Greeting"], Model.InstructorFirstName)</h1>
<p class="email-text">
    @Model.Strings["CourseAdminUnpublished_Body"]
</p>
<div class="alert-light">
    <p class="alert-light-text">@Model.CourseTitle</p>
</div>
<p class="email-text">
    @Model.Strings["CourseAdminUnpublished_BodyDraft"]
</p>
