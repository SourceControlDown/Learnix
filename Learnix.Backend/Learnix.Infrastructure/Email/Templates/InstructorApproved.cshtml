@model Learnix.Infrastructure.Email.Models.InstructorApprovedModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = Model.Strings["InstructorApproved_Subject"].Value;
}

<h1 class="email-heading">@string.Format(Model.Strings["InstructorApproved_Greeting"], Model.FirstName)</h1>
<p class="email-text">
    @Model.Strings["InstructorApproved_Body"]
</p>
<p class="email-text-lg">
    @Model.Strings["InstructorApproved_BodyCta"]
</p>
<table role="presentation" cellpadding="0" cellspacing="0">
    <tr>
        <td class="badge-success-container">
            <span class="badge-success">
                @Model.Strings["InstructorApproved_Badge"]
            </span>
        </td>
    </tr>
</table>
