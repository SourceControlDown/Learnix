@model Learnix.Infrastructure.Email.Models.InstructorApprovedModel
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Заявку схвалено</title>
</head>
<body style="margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;background-color:#f3f4f6;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f3f4f6;padding:48px 16px;">
    <tr>
      <td align="center">
        <table width="560" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 1px 6px rgba(0,0,0,0.08);">
          <tr>
            <td style="background-color:#4f46e5;padding:28px 40px;text-align:center;">
              <span style="color:#ffffff;font-size:22px;font-weight:700;letter-spacing:0.5px;">Learnix</span>
            </td>
          </tr>
          <tr>
            <td style="padding:40px;">
              <h1 style="margin:0 0 12px;color:#111827;font-size:20px;font-weight:700;">Вітаємо, @Model.FirstName!</h1>
              <p style="margin:0 0 20px;color:#4b5563;font-size:15px;line-height:1.7;">
                Ваша заявка на отримання ролі <strong>Інструктора</strong> на платформі Learnix була <strong>схвалена</strong>.
              </p>
              <p style="margin:0 0 28px;color:#4b5563;font-size:15px;line-height:1.7;">
                Тепер ви можете створювати та публікувати курси. Увійдіть до свого акаунта, щоб розпочати.
              </p>
              <table cellpadding="0" cellspacing="0">
                <tr>
                  <td style="background-color:#16a34a;border-radius:6px;">
                    <span style="display:inline-block;padding:10px 24px;color:#ffffff;font-size:14px;font-weight:600;">
                      ✓ Роль Інструктора активовано
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 40px;border-top:1px solid #e5e7eb;text-align:center;">
              <p style="margin:0;color:#9ca3af;font-size:12px;">© Learnix — Платформа онлайн-навчання</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
