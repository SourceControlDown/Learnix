<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewBag.Title</title>
  <style>
    @Raw(System.IO.File.ReadAllText(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Email", "Templates", "styles.css")))
  </style>
</head>
<body>
  <table cellpadding="0" cellspacing="0" class="email-wrapper">
    <tr>
      <td align="center">
        <table cellpadding="0" cellspacing="0" class="email-container">
          <tr>
            <td class="email-header">
              <span class="email-header-title">Learnix</span>
            </td>
          </tr>
          <tr>
            <td class="email-body">
              @RenderBody()
            </td>
          </tr>
          <tr>
            <td class="email-footer">
              <p class="email-footer-text">© Learnix — Платформа онлайн-навчання</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
