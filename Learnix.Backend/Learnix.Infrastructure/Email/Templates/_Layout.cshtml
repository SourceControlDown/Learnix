@using System.Globalization
@{
    var logoSrc = "cid:learnix-logo";
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewBag.Title</title>
  <style>
    @Raw(System.IO.File.ReadAllText(System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Email", "Templates", "styles.css")))
  </style>
</head>
<body>
  <table cellpadding="0" cellspacing="0" class="email-wrapper">
    <tr>
      <td align="center">
        <table cellpadding="0" cellspacing="0" class="email-container">
          <tr>
            <td class="email-header">
              <table cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td align="center" style="padding: 10px 0;">
                    <a href="@Model.ClientBaseUrl" style="text-decoration: none; display: inline-block;">
                      <table cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td valign="middle">
                            <div style="background-color: #ffffff; border-radius: 8px; width: 40px; height: 40px; text-align: center; margin-right: 12px; display: inline-block;">
                              <table cellpadding="0" cellspacing="0" border="0" width="40" height="40">
                                <tr>
                                  <td align="center" valign="middle">
                                    <img src="@logoSrc" alt="Learnix Logo" style="width: 24px; height: 24px; display: block; border: 0;" />
                                  </td>
                                </tr>
                              </table>
                            </div>
                          </td>
                          <td valign="middle">
                            <span class="email-header-title">Learnix</span>
                          </td>
                        </tr>
                      </table>
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td class="email-body">
              @RenderBody()
            </td>
          </tr>
          <tr>
            <td class="email-footer">
              <p class="email-footer-text">© Learnix — @(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "uk" ? "Платформа онлайн-навчання" : "Online Learning Platform")</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
