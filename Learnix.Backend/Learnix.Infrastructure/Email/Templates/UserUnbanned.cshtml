@model Learnix.Infrastructure.Email.Models.UserUnbannedModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.Title = "Обліковий запис розблоковано";
}

<h1 class="email-heading">Привіт, @Model.FirstName!</h1>
<p class="email-text">
    Ваш обліковий запис на платформі <strong>Learnix</strong> було <strong>розблоковано</strong>.
    Тепер ви знову можете користуватися всіма функціями платформи.
</p>
<p class="email-text">
    Будь ласка, дотримуйтесь правил спільноти, щоб уникнути повторного блокування.
</p>
