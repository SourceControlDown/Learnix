{
  "name": "learnix",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "Learnix.Backend/**/*.cs": [
      "dotnet format Learnix.Backend/Learnix.Backend.slnx --no-restore"
    ],
    "learnix-client/src/**/*.{ts,tsx,js,jsx,css,scss,md}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2"
  }
}
