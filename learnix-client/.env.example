VITE_API_URL=http://localhost:5000/api
# REQUIRED for Google Login. See docs/API_KEYS_GUIDE.md. 
# Leave as dummy if you don't want to configure it right now.
VITE_GOOGLE_CLIENT_ID=dummy_id.apps.googleusercontent.com
# Public origin of the site — used for canonical URLs, og:url and og:image, and for the
# build-time sitemap generator. Must be the origin crawlers actually hit in production.
VITE_SITE_URL=http://localhost:5173
# Shows the "portfolio project" notice banner on the landing page and FAQ.
# Shown by default; set to false to hide it (e.g. for a clean demo).
VITE_SHOW_PROJECT_BANNER=true
